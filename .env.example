# Copier ce fichier en .env et remplir les valeurs
# Ce fichier est lu automatiquement par docker-compose

# Mot de passe PostgreSQL (choisir quelque chose de solide en prod)
POSTGRES_PASSWORD=changeme

# Clé API OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-...

# Grafana Cloud — Prometheus remote write
GRAFANA_PROM_URL=https://prometheus-prod-XX.grafana.net/api/prom/push
GRAFANA_PROM_USER=123456
GRAFANA_PROM_PASSWORD=

# Grafana Cloud — Loki logs
GRAFANA_LOKI_URL=https://logs-prod-XX.grafana.net/loki/api/v1/push
GRAFANA_LOKI_USER=123456
GRAFANA_LOKI_PASSWORD=
